# ============================================================
# Powerline — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/powerline

# Redis (Celery broker + call state cache)
REDIS_URL=redis://redis:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ============================================================
# Twilio
# All fields are required for full functionality.
# Dev mode: leave empty to skip actual call placement.
# ============================================================

# Main account credentials — console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# TwiML App SID — console.twilio.com → Voice → TwiML Apps
# Set Voice Request URL to: https://YOUR_DOMAIN/webhooks/twilio/voice-app
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio phone number to use as caller ID for outbound calls
TWILIO_FROM_NUMBER=+15555555555

# API Key for WebRTC AccessToken generation (separate from AUTH_TOKEN).
# Create at: console.twilio.com → Account → API Keys & Tokens → Create API Key
# SID starts with SK (not AC).
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# Public base URL — required so Twilio can reach your webhook callbacks.
# Dev: use ngrok (e.g. https://abc123.ngrok.io)
# Production: your actual domain (e.g. https://api.powerline.example.com)
PUBLIC_BASE_URL=https://your-domain.com

# ============================================================
# Cloudinary (audio file hosting)
# Get credentials from cloudinary.com → Dashboard
# Leave empty to use TTS-only audio (no file uploads).
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# CORS
# Comma-separated list of allowed origins, or * for all.
# Use * during development and for the public embed API.
# In production, restrict to your frontend: https://app.example.com
# ============================================================
CORS_ORIGINS=*
